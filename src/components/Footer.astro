          </li>
        </ul>
      </div>

      <div>
        <p class="text-xs tracking-[0.25em] uppercase text-sand mb-5">
          Contato
        </p>
        <ul class="space-y-3 text-sm text-cream/80">
          <li>
            <a
              href="https://wa.me/5551999414246"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-ink-dark"
            >
              (51) 99941-4246
            </a>
          </li>
          <li>
            <a
              href="mailto:brunaschlos.arq@gmail.com"
              class="hover:text-ink-dark"
            >
              brunaschlos.arq@gmail.com
