---
const year = new Date().getFullYear();
---

<footer class="bg-ink text-cream">
  <div class="container-site py-16 md:py-20">
    <div
      class="grid gap-12 md:grid-cols-3 md:gap-8 border-b border-white/10 pb-12"
    >
      <div>
        <p class="font-serif text-2xl md:text-3xl tracking-wide">
          Bruna Schlos
        </p>
        <p
          class="mt-2 text-xs tracking-[0.2em] uppercase text-sand font-mono"
        >
          [ Arquitetura de Interiores ]
        </p>
        <p class="mt-6 text-sm text-cream/70 max-w-xs leading-relaxed">
          Transformando espaços em ambientes acolhedores e funcionais desde
          2019, em Porto Alegre.
        </p>
      </div>

      <div>
        <p
          class="text-xs tracking-[0.25em] uppercase text-sand mb-5"
        >
          Navegação
        </p>
        <ul class="space-y-3 text-sm text-cream/80">
          <li>
            <a href="#sobre" class="hover:text-sand-light"><span class="font-mono text-[0.65rem] text-muted mr-1 opacity-70">01.</span>Sobre</a>
          </li>
          <li>
            <a href="#servicos" class="hover:text-sand-light"><span class="font-mono text-[0.65rem] text-muted mr-1 opacity-70">02.</span>Serviços</a>
          </li>
          <li>
            <a href="#projetos" class="hover:text-sand-light"><span class="font-mono text-[0.65rem] text-muted mr-1 opacity-70">03.</span>Projetos</a>
          </li>
          <li>
            <a href="#contato" class="hover:text-sand-light"><span class="font-mono text-[0.65rem] text-muted mr-1 opacity-70">04.</span>Contato</a>
          </li>
        </ul>
      </div>

      <div>
        <p
          class="text-xs tracking-[0.25em] uppercase text-sand mb-5"
        >
          Contato
        </p>
        <ul class="space-y-3 text-sm text-cream/80">
          <li>
            <a
              href="https://wa.me/5551999414246"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-sand-light"
            >
              (51) 99941-4246
            </a>
          </li>
          <li>
            <a
              href="mailto:contato@brunaschlos.com.br"
              class="hover:text-sand-light"
            >
              contato@brunaschlos.com.br
            </a>
          </li>
          <li>
            <a
              href="https://instagram.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-sand-light"
            >
              Instagram
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div
      class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 pt-8 text-xs text-cream/45 tracking-wide"
    >
      <div>
        <p>© {year} Bruna Schlos Arquitetura de Interiores. Todos os direitos reservados.</p>
        <div class="mt-2 flex flex-wrap gap-4 font-mono text-[0.55rem] text-cream/30 uppercase">
          <span>[ COD: BS-WEB ]</span>
          <span>[ REV: 02 ]</span>
          <span>[ ARQ: B. SCHLOS ]</span>
        </div>
      </div>
      <p class="text-[0.65rem] tracking-[0.2em] uppercase text-cream/40 font-mono">
        ARQUITETURA CRIATIVA E AFETIVA
      </p>
    </div>
  </div>
</footer>
