---
interface Props {
  number: string;
  title: string;
  description: string;
  items?: string[];
  delay?: string;
  cta?: string;
  href?: string;
  footerText?: string;
  image?: string;
}

const {
  number,
  title,
  description,
  items = [],
  delay = "",
  cta,
  href,
  footerText,
  image,
} = Astro.props;
---

<article
  class:list={[
    "reveal group relative rounded-sm border border-line/60 bg-cream p-8 md:p-12 transition-all duration-500 hover:border-sand hover:shadow-xl hover:shadow-ink/5 hover:-translate-y-1",
    delay,
  ]}
>
  <!-- Technical anchor crosshair -->

  <div class="grid lg:grid-cols-12 gap-8 lg:gap-16">
    <!-- Left Column: Number, Title, Desktop CTA -->
    <div class="lg:col-span-5 flex flex-col items-start">
      <h3
        class="font-serif text-2xl md:text-3xl lg:text-4xl text-ink leading-tight text-balance"
      >
        {title}
      </h3>

      {image && (
        <div class="w-full flex justify-center mt-8 mb-4">
          <img src={image} alt="" class="w-24 h-24 md:w-32 md:h-32 object-contain mix-blend-multiply" />
        </div>
      )}

      {
        cta && (
          <div class="hidden lg:block mt-auto pt-8 w-full">
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center px-6 py-3 bg-terracotta text-cream text-xs uppercase tracking-wider font-medium rounded-sm hover:bg-terracotta-dark transition-colors duration-300 w-full"
            >
              {cta}
            </a>
          </div>
        )
      }
    </div>

    <!-- Right Column: Description, Items, Mobile CTA -->
    <div class="lg:col-span-7 flex flex-col justify-center">
      <p class="text-sm md:text-base text-ink-soft leading-relaxed">
        {description}
      </p>

      {
        items && items.length > 0 && (
          <ul class="mt-8 space-y-2.5 border-t border-line/50 pt-6">
            {items.map((item) => (
              <li class="flex items-start gap-3 text-sm text-ink-soft">
                <span
                  class="mt-2.5 h-1.5 w-1.5 shrink-0 bg-terracotta rotate-45"
                  aria-hidden="true"
                />
                <span class="flex-1 leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>
        )
      }

      {
        footerText && (
          <p class="mt-6 text-sm md:text-base text-ink-soft leading-relaxed font-medium">
            {footerText}
          </p>
        )
      }

      {
        cta && (
          <div class="lg:hidden mt-8 pt-6 border-t border-line/50 text-center">
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block px-6 py-3 bg-terracotta text-cream text-xs uppercase tracking-wider font-medium rounded-sm hover:bg-terracotta-dark transition-colors duration-300 w-full"
            >
              {cta}
            </a>
          </div>
        )
      }
    </div>
  </div>
</article>
