---
const testimonials = [
  {
    name: "Anna",
    project: "Cliente Apê Sofia",
    text: "Tive o prazer de acompanhar o projeto espetacular que a Bruna fez com êxito para a minha irmã, e fiquei encantada, e sem nenhuma dúvida de que ela seria a mente condutora e brilhante de ideias lindas do meu.",
    link: "https://www.instagram.com/p/DVi-vX3lZKY/?igsh=YTBudjZ2djVzcnA2",
  },
  {
    name: "Luciana",
    project: "Cliente Apê Demétrio",
    text: 'Desde sempre tive o sonho da "casinha" que fosse com a minha cara.\nA Bruna conseguiu captar tudo isso e, a partir de muitas conversas, conseguiu transformar cada cantinho do apê de maneira única e acolhedora.\nO projeto atendeu em cheio todas as minhas expectativas.\nMuito obrigada por realizar este sonho.',
    link: "https://www.instagram.com/p/DCh4YrXud14/?igsh=MTVzbHgzZmJsdDZmcA==",
  },
];
---

<section
  id="depoimentos"
  class="py-24 md:py-32 bg-cream relative overflow-hidden border-t border-line/40"
>
  <!-- Blueprint Section Line (Signature) -->
  <div
    class="absolute left-0 right-0 top-0 flex justify-between px-6 md:px-12 pointer-events-none"
    aria-hidden="true"
  >
    <span class="font-mono text-[0.55rem] text-ink/65 tracking-widest pt-1.5">
      [ SEC_05 / DEPOIMENTOS ]
    </span>
    <span class="font-mono text-[0.55rem] text-ink/65 tracking-widest pt-1.5">
      REF: S-05
    </span>
  </div>

  <div class="container-site relative z-10">
    <div class="mb-16 md:mb-24 text-center max-w-2xl mx-auto">
      <p class="reveal text-xs tracking-[0.3em] uppercase text-ink mb-4">
        Feedback
      </p>
      <h2
        class="reveal reveal-delay-1 font-serif text-4xl md:text-5xl text-ink text-balance"
      >
        O que dizem nossos clientes
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-8 md:gap-12 max-w-5xl mx-auto">
      {
        testimonials.map((t, i) => (
          <a
            href={t.link}
            target="_blank"
            rel="noopener noreferrer"
            class:list={[
              "reveal group bg-white/60 backdrop-blur-md p-8 md:p-10 rounded-[2rem] border border-white/40 shadow-xl shadow-ink/5 relative block hover:scale-[1.02] hover:bg-white/80 transition-all duration-300",
              i === 1 && "reveal-delay-1",
            ]}
          >
            <div class="mb-6">
              <h3 class="font-serif text-2xl text-ink font-medium">{t.name}</h3>
              <p class="font-sans text-sm uppercase tracking-wider text-ink/70 mt-1">
                {t.project}
              </p>
            </div>
            <p class="font-sans text-ink/90 text-[1.05rem] leading-relaxed mb-10 whitespace-pre-line">
              {t.text}
            </p>
            <div class="absolute bottom-6 right-8 flex items-center gap-4 text-ink/70">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="group-hover:text-ink transition-colors"
              >
                <path d="M17 2.1l4 4-4 4" />
                <path d="M3 12.2v-2a4 4 0 0 1 4-4h13.8" />
                <path d="M7 21.9l-4-4 4-4" />
                <path d="M21 11.8v2a4 4 0 0 1-4 4H3.2" />
              </svg>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="text-ink group-hover:scale-110 transition-transform"
              >
                <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z" />
              </svg>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
