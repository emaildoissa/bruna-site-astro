---
const images = [
  "/assets/hero_living_room.jpg",
  "/carrossel/Ap-Sa-Sala-02.jpg",
  "/carrossel/ApdoBe-Arq.-Bruna-Schlos-sala-e-cozinha-01.jpg",
  "/carrossel/2024-02-06-0249-Bruna-Schlos-Arq-Ape-Demetrio-_MG_0740-scaled.jpg"
];
---

<section
  id="topo"
  class="relative min-h-[100svh] flex items-center justify-center overflow-hidden"
>
  <!-- Full-screen Background Carousel -->
  <div class="absolute inset-0 -z-20 bg-ink" id="fullscreen-carousel">
    {images.map((src, index) => (
      <div 
        class={`bg-slide absolute inset-0 transition-opacity duration-500 ease-in-out ${index === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0'}`}
      >
        <img
          src={src}
          alt={`Bruna Schlos Arquitetura - Slide ${index + 1}`}
          class="h-full w-full object-cover ken-burns-img"
        />
      </div>
    ))}
  </div>

  <!-- Dark Gradient Overlay for Readability -->
  <div class="absolute inset-0 -z-10 bg-gradient-to-r from-ink/95 via-ink/70 to-ink/20"></div>

  <!-- Content -->
  <div class="container-site w-full relative z-10 pt-20">
    <div class="max-w-3xl">
      <p
        class="reveal text-xs md:text-sm tracking-[0.35em] uppercase text-sand-light mb-6 md:mb-8"
      >
        Porto Alegre · desde 2019
      </p>

      <h1
        class="reveal reveal-delay-1 font-serif text-[clamp(3.5rem,8vw,6.5rem)] text-cream text-balance leading-[1.05]"
      >
        Arquitetura que<br />
        <em class="italic text-terracotta">acolhe</em>
        e transforma
      </h1>

      <p
        class="reveal reveal-delay-2 mt-6 md:mt-8 max-w-xl text-base md:text-lg text-cream/80 leading-relaxed font-light"
      >
        Bruna Schlos Arquitetura de Interiores — projetos residenciais focados
        em transformar o físico em acolhedor, unindo a sofisticação de alto
        padrão ao aconchego de um lar sob medida.
      </p>

      <div
        class="reveal reveal-delay-3 mt-10 flex flex-wrap items-center gap-4 md:gap-6"
      >
        <a
          href="#projetos"
          class="inline-flex items-center gap-2 rounded-full bg-terracotta px-8 py-4 text-sm text-white tracking-wide hover:bg-terracotta-dark transition-colors"
        >
          Ver projetos
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            class="h-4 w-4"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
              clip-rule="evenodd"></path>
          </svg>
        </a>
        <a
          href="#sobre"
          class="inline-flex items-center gap-2 rounded-full border border-line/30 bg-ink/40 backdrop-blur-sm px-8 py-4 text-sm text-cream tracking-wide hover:border-line/80 hover:bg-ink/60 transition-colors"
        >
          Conheça o escritório
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll hint -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 hidden md:flex flex-col items-center gap-2 text-cream/60"
    aria-hidden="true"
  >
    <span class="text-[0.6rem] tracking-[0.3em] uppercase">Scroll</span>
    <span class="scroll-line block h-8 w-px bg-line/60"></span>
  </div>
</section>

<script>
  function initHeroBackgroundCarousel() {
    const slides = document.querySelectorAll('.bg-slide');
    if (slides.length <= 1) return;
    
    if (window.heroBgInterval) clearInterval(window.heroBgInterval);
    
    let currentIndex = 0;
    
    // Set initial ken burns state
    slides[0].querySelector('.ken-burns-img')?.classList.add('is-active');

    window.heroBgInterval = setInterval(() => {
      // Fade out current slide
      slides[currentIndex].classList.remove('opacity-100', 'z-10');
      slides[currentIndex].classList.add('opacity-0', 'z-0');
      slides[currentIndex].querySelector('.ken-burns-img')?.classList.remove('is-active');
      
      // Move to next slide
      currentIndex = (currentIndex + 1) % slides.length;
      
      // Fade in next slide
      slides[currentIndex].classList.remove('opacity-0', 'z-0');
      slides[currentIndex].classList.add('opacity-100', 'z-10');
      slides[currentIndex].querySelector('.ken-burns-img')?.classList.add('is-active');
    }, 5000);
  }

  // Initialize
  initHeroBackgroundCarousel();
  document.addEventListener('astro:page-load', initHeroBackgroundCarousel);
</script>

<style>
  .scroll-line {
    animation: scroll-pulse 1.8s ease-in-out infinite;
    transform-origin: top;
  }

  @keyframes scroll-pulse {
    0%,
    100% {
      opacity: 0.3;
      transform: scaleY(0.6);
    }
    50% {
      opacity: 1;
      transform: scaleY(1);
    }
  }

  /* Ken Burns Effect */
  .ken-burns-img {
    transform: scale(1);
    transition: transform 6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  
  .ken-burns-img.is-active {
    transform: scale(1.1);
  }
</style>
