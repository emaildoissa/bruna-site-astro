---
const contacts = [
  {
    label: "WhatsApp",
    value: "(51) 99941-4246",
    href: "https://wa.me/5551999414246?text=Ol%C3%A1%20Bruna!%20Gostaria%20de%20conversar%20sobre%20um%20projeto.",
    external: true,
  },
  {
    label: "E-mail",
    value: "contato@brunaschlos.com.br",
    href: "mailto:contato@brunaschlos.com.br",
    external: false,
  },
  {
    label: "Instagram",
    value: "@brunaschlos",
    href: "https://instagram.com/",
    external: true,
  },
  {
    label: "Endereço",
    value: "R. Felicíssimo de Azevedo, 400 — Porto Alegre, RS",
    href: "https://maps.google.com/?q=R.+Felic%C3%ADssimo+de+Azevedo,+400,+Porto+Alegre",
    external: true,
  },
];
---

<section id="contato" class="py-24 md:py-32 bg-cream-dark relative overflow-hidden border-t border-line/40">
  <!-- Blueprint Section Line (Signature) -->
  <div class="absolute left-0 right-0 top-0 flex justify-between px-6 md:px-12 pointer-events-none" aria-hidden="true">
    <span class="font-mono text-[0.55rem] text-muted/65 tracking-widest pt-1.5">
      [ SEC_05 / CONTATO & DIAGNÓSTICO ]
    </span>
    <span class="font-mono text-[0.55rem] text-muted/65 tracking-widest pt-1.5">
      REF: S-05
    </span>
  </div>

  <div class="container-site relative">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      <!-- Left Contact Column -->
      <div class="lg:col-span-5 space-y-8">
        <div>
          <p
            class="reveal text-xs tracking-[0.3em] uppercase text-terracotta-dark mb-4"
          >
            Contato
          </p>
          <h2
            class="reveal reveal-delay-1 font-serif text-3xl md:text-4xl lg:text-5xl text-ink leading-tight"
          >
            Vamos conversar sobre o seu projeto?
          </h2>
          <p
            class="reveal reveal-delay-2 mt-4 text-sm md:text-base text-ink-soft leading-relaxed"
          >
            Conte um pouco sobre o espaço, o momento e o que você imagina. Será um
            prazer entender como a arquitetura pode transformar o seu dia a dia.
          </p>
        </div>

        <!-- Contact card list -->
        <div
          class="reveal reveal-delay-3 rounded-sm border border-line bg-white/60 backdrop-blur-sm p-6 md:p-8 relative"
        >
          <ul class="divide-y divide-line/60">
            {
              contacts.map((item, idx) => (
                <li class="py-4 first:pt-0 last:pb-0 relative">
                  <div class="absolute top-4 right-0 font-mono text-[0.55rem] text-muted/40 select-none">[ C_0{idx + 1} ]</div>
                  <p class="text-[0.6rem] tracking-[0.25em] uppercase text-muted mb-1">
                    {item.label}
                  </p>
                  <a
                    href={item.href}
                    target={item.external ? "_blank" : undefined}
                    rel={item.external ? "noopener noreferrer" : undefined}
                    class="text-sm md:text-base text-ink hover:text-terracotta transition-colors font-medium break-all"
                  >
                    {item.value}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <!-- Right Map Column (Poa Map Graphic) -->
      <div class="lg:col-span-7 reveal reveal-delay-4">
        <div class="relative aspect-[4/3] overflow-hidden rounded-sm border border-line/60 shadow-2xl shadow-ink/10 group">
          <img
            src="/assets/poa_map.jpg"
            alt="Mapa conceitual do escritório de Bruna Schlos no bairro São João em Porto Alegre"
            class="absolute inset-0 h-full w-full object-cover transition-transform duration-[1.5s] ease-out group-hover:scale-102"
          />
          <div class="absolute inset-3 border border-ink/5 pointer-events-none"></div>
          <span class="absolute bottom-2.5 left-3 font-mono text-[0.55rem] text-ink/40">ref: c-05 / localização</span>
          <span class="absolute top-2.5 right-3 font-mono text-[0.55rem] text-ink/40">bairro são joão</span>
        </div>
      </div>
    </div>
  </div>
</section>
