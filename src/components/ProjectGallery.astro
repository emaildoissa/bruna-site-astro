---
import type { CollectionEntry } from "astro:content";

interface Props {
  projects: CollectionEntry<"projects">[];
}

const { projects } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
  {
    projects.map((project, i) => {
      const { title, year, coverGradient, coverImage, slug } = project.data;

      return (
        <a
          href={`/projetos/${slug}`}
          class:list={[
            "reveal group relative block overflow-hidden rounded-sm",
            i === 1 && "reveal-delay-1",
            i === 2 && "reveal-delay-2",
            i === 3 && "reveal-delay-3",
          ]}
        >
          <div class="relative overflow-hidden aspect-[4/3] md:aspect-[4/3]">
            {
              coverImage ? (
                <img
                  src={coverImage}
                  alt={title}
                  class="absolute inset-0 h-full w-full object-cover transition-transform duration-[1.2s] ease-out group-hover:scale-105"
                />
              ) : (
                <div
                  class="absolute inset-0 transition-transform duration-700 ease-out group-hover:scale-105"
                  style={`background: ${coverGradient};`}
                />
              )
            }
            <div
              class="absolute inset-0 bg-gradient-to-t from-gray-900/90 via-gray-900/30 to-transparent opacity-90 transition-opacity duration-300 group-hover:opacity-100"
              aria-hidden="true"
            />

            <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8 flex flex-col justify-end">
              <h3 class="font-serif text-2xl md:text-3xl text-cream mb-4">
                {title}
              </h3>
              
              <div class="flex items-center justify-between border-t border-cream/20 pt-4">
                <span class="font-mono text-[0.65rem] uppercase tracking-wider text-cream/70">
                  ANO: {year}
                </span>
                <span class="inline-flex items-center gap-2 text-sm text-cream tracking-wide font-medium">
                  Ver projeto
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1.5"
                    aria-hidden="true"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </span>
              </div>
            </div>
          </div>
        </a>
      );
    })
  }
</div>
