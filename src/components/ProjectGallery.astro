---
import type { CollectionEntry } from "astro:content";

interface Props {
  projects: CollectionEntry<"projects">[];
}

const { projects } = Astro.props;
---

<div class="grid md:grid-cols-2 gap-6 md:gap-8">
  {
    projects.map((project, i) => {
      const { title, category, location, year, excerpt, coverGradient, coverImage, slug } =
        project.data;
      const isLarge = i === 0;

      return (
        <a
          href={`/projetos/${slug}`}
          class:list={[
            "reveal group relative block overflow-hidden rounded-sm",
            isLarge && "md:col-span-2 md:grid md:grid-cols-2",
            i === 1 && "reveal-delay-1",
            i === 2 && "reveal-delay-2",
            i === 3 && "reveal-delay-3",
          ]}
        >
          <div
            class:list={[
              "relative overflow-hidden",
              isLarge ? "aspect-[16/10] md:aspect-auto md:min-h-[28rem]" : "aspect-[4/3]",
            ]}
          >
            {
              coverImage ? (
                <img
                  src={coverImage}
                  alt={title}
                  class="absolute inset-0 h-full w-full object-cover transition-transform duration-[1.2s] ease-out group-hover:scale-105"
                />
              ) : (
                <div
                  class="absolute inset-0 transition-transform duration-700 ease-out group-hover:scale-105"
                  style={`background: ${coverGradient};`}
                />
              )
            }
            <div
              class="absolute inset-0 bg-gradient-to-t from-ink/75 via-ink/20 to-transparent opacity-90"
              aria-hidden="true"
            />

            <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8">
              <span class="font-mono text-[0.65rem] tracking-[0.2em] uppercase text-cream/80 bg-ink/40 backdrop-blur-xs px-2 py-0.5 border border-cream/20">
                [ {category} ]
              </span>
              <h3 class="mt-3 font-serif text-2xl md:text-3xl text-cream">
                {title}
              </h3>
            </div>
          </div>

          <div
            class:list={[
              "bg-white border border-line border-t-0 p-6 md:p-8 flex flex-col justify-center transition-colors group-hover:border-sand relative",
              isLarge && "md:border-t md:border-l-0",
            ]}
          >
            <!-- Blueprint crosshair signature -->
            <div class="absolute bottom-2 right-2 font-mono text-[0.55rem] text-muted/20 select-none">⊕ PRJ_{year}</div>

            <div class="flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-[0.65rem] uppercase tracking-wider text-muted">
              <span>{location}</span>
              <span class="text-line" aria-hidden="true">
                |
              </span>
              <span>ANO: {year}</span>
            </div>
            <p class="mt-4 text-sm md:text-base text-ink-soft leading-relaxed">
              {excerpt}
            </p>
            <span class="mt-6 inline-flex items-center gap-2 text-sm text-terracotta-dark tracking-wide font-medium">
              Ver projeto
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 20 20"
                fill="currentColor"
                class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1.5"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
                  clip-rule="evenodd"
                />
              </svg>
            </span>
          </div>
        </a>
      );
    })
  }
</div>
