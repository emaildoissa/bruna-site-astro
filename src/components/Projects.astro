---
import { getCollection } from "astro:content";
import ProjectGallery from "./ProjectGallery.astro";

const allProjects = await getCollection("projects");
const projects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<section
  id="projetos"
  class="py-24 md:py-32 bg-white relative overflow-hidden border-t border-line/40"
>
  <div class="container-site">
    <div
      class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-14 md:mb-20"
    >
      <div class="max-w-xl">
        <p
          class="reveal text-xs tracking-[0.3em] uppercase text-terracotta-dark mb-4"
        >
          Portfólio
        </p>
        <h2
          class="reveal reveal-delay-1 font-serif text-4xl md:text-5xl text-ink text-balance"
        >
          Projetos em destaque
        </h2>
      </div>
      <p
        class="reveal reveal-delay-2 max-w-sm text-sm text-muted leading-relaxed"
      >
        Uma seleção de trabalhos que mostram o olhar do escritório — da escala
        residencial ao detalhe de interiores.
      </p>
    </div>

    <ProjectGallery projects={projects} />

    <!-- Meus Projetos Banner (Original Site content with blueprint style) -->
    <div
      class="mt-24 md:mt-32 grid lg:grid-cols-12 gap-12 lg:gap-16 items-center"
    >
      <div class="lg:col-span-5 order-2 lg:order-1 relative">
        <div
          class="absolute inset-0 bg-cream-dark/50 -left-6 -top-6 -bottom-6 -right-6 -z-10 rounded-sm"
        >
        </div>
        <div
          class="bg-white p-8 md:p-12 border border-line/65 shadow-xl shadow-ink/5 relative rounded-sm"
        >
          <h3 class="font-serif text-3xl text-ink mb-6">
            Ambientes onde a vida acontece
          </h3>
          <p class="text-sm md:text-base text-ink-soft leading-relaxed mb-8">
            O principal propósito do escritório é influenciar positivamente a
            vida das pessoas, transformando o ambiente físico, onde a vida
            acontece, em um local mais agradável, funcional e acolhedor.
          </p>
          <a
            href="https://wa.me/5551999414246?text=Ol%C3%A1%20Bruna!%20Gostaria%20de%20conversar%20sobre%20um%20projeto."
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-wider text-ink border-b border-ink pb-1 hover:text-terracotta hover:border-terracotta transition-colors"
          >
            Fale sobre seu espaço <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 20 20"
              fill="currentColor"
              class="h-3.5 w-3.5"
              ><path
                fill-rule="evenodd"
                d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
                clip-rule="evenodd"></path></svg
            >
          </a>
        </div>
      </div>
      <div class="lg:col-span-7 order-1 lg:order-2">
        <div
          class="relative aspect-[3/2] overflow-hidden rounded-sm border border-line/60 shadow-2xl shadow-ink/10 group"
        >
          <img
            src="/assets/banner_kitchen.jpeg"
            alt="Cozinha aconchegante com parede de tijolos e marcenaria em madeira por Bruna Schlos"
            class="absolute inset-0 h-full w-full object-cover transition-transform duration-[1.5s] ease-out group-hover:scale-105"
          />
          <div
            class="absolute inset-3 border border-white/10 pointer-events-none"
          >
          </div>
          <span
            class="absolute bottom-2 left-3 font-mono text-[0.55rem] text-white/35"
            >det: 04 / cozinha</span
          >
          <span
            class="absolute top-2 right-3 font-mono text-[0.55rem] text-white/35"
            >ref: arq-04</span
          >
        </div>
      </div>
    </div>
  </div>
</section>
