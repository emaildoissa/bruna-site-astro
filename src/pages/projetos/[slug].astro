---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.data.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, category, location, year, excerpt, coverGradient, coverImage, concept, elements } =
  project.data;
---

<Layout
  title={`${title} | Bruna Schlos Arquitetura`}
  description={excerpt}
>
  <article>
    <!-- Hero cover -->
    <header class="relative min-h-[55svh] md:min-h-[65svh] flex items-end overflow-hidden">
      {
        coverImage ? (
          <img
            src={coverImage}
            alt={title}
            class="absolute inset-0 h-full w-full object-cover"
          />
        ) : (
          <div
            class="absolute inset-0"
            style={`background: ${coverGradient};`}
          />
        )
      }
      <div
        class="absolute inset-0 bg-gradient-to-t from-ink/90 via-ink/30 to-ink/20"
        aria-hidden="true"
      >
      </div>

      <div class="container-site relative z-10 pb-12 md:pb-16 pt-32">
        <a
          href="/#projetos"
          class="inline-flex items-center gap-2 text-sm text-cream/80 hover:text-cream mb-8 tracking-wide"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            class="h-4 w-4"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z"
              clip-rule="evenodd"></path>
          </svg>
          Voltar aos projetos
        </a>

        <p
          class="text-[0.7rem] tracking-[0.3em] uppercase text-sand-light mb-4"
        >
          {category}
        </p>
        <h1 class="font-serif text-4xl md:text-6xl text-cream max-w-3xl">
          {title}
        </h1>
        <div
          class="mt-5 flex flex-wrap gap-x-4 gap-y-1 text-sm text-cream/75"
        >
          <span>{location}</span>
          <span aria-hidden="true">·</span>
          <span>{year}</span>
        </div>
      </div>
    </header>

    <div class="bg-cream py-16 md:py-24">
      <div class="container-site">
        <div class="grid lg:grid-cols-12 gap-12">
          <div class="lg:col-span-4 space-y-8">
            <div>
              <p
                class="text-[0.6rem] tracking-[0.25em] uppercase text-muted mb-3 font-mono"
              >
                [ DET_01 / MEMORIAL DESCRIÇÃO ]
              </p>
              <p class="font-serif text-2xl md:text-3xl text-ink leading-snug">
                {excerpt}
              </p>
            </div>

            {
              (concept || elements) && (
                <div class="border-t border-line/60 pt-6 space-y-5 font-sans">
                  {concept && (
                    <div>
                      <p class="font-mono text-[0.6rem] text-muted uppercase tracking-widest mb-1.5">[ CONCEITO ]</p>
                      <p class="text-sm text-ink-soft leading-relaxed">{concept}</p>
                    </div>
                  )}
                  {elements && (
                    <div>
                      <p class="font-mono text-[0.6rem] text-muted uppercase tracking-widest mb-1.5">[ ELEMENTOS & MATERIAIS ]</p>
                      <p class="text-sm text-ink-soft leading-relaxed">{elements}</p>
                    </div>
                  )}
                </div>
              )
            }
          </div>

          <div
            class="lg:col-span-7 lg:col-start-6 prose-project text-ink-soft leading-relaxed space-y-5 text-base md:text-lg"
          >
            <Content />
          </div>
        </div>

        <div
          class="mt-16 md:mt-24 rounded-sm border border-line bg-white p-8 md:p-12 flex flex-col md:flex-row md:items-center md:justify-between gap-6"
        >
          <div>
            <p class="font-serif text-2xl md:text-3xl text-ink">
              Gostou deste projeto?
            </p>
            <p class="mt-2 text-sm text-muted max-w-md">
              Vamos conversar sobre como transformar o seu espaço com o mesmo
              cuidado e olhar criativo.
            </p>
          </div>
          <a
            href="https://wa.me/5551999414246?text=Ol%C3%A1%20Bruna!%20Vi%20o%20projeto%20e%20gostaria%20de%20conversar."
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex shrink-0 items-center justify-center rounded-full bg-ink px-7 py-3.5 text-sm text-cream tracking-wide hover:bg-terracotta-dark transition-colors"
          >
            Falar no WhatsApp
          </a>
        </div>
      </div>
    </div>
  </article>
</Layout>

<style>
  .prose-project :global(p) {
    margin-bottom: 1.25rem;
  }

  .prose-project :global(strong) {
    color: var(--color-ink);
    font-weight: 500;
  }

  .prose-project :global(a) {
    color: var(--color-terracotta-dark);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
